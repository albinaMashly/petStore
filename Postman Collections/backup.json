										"exec": [
											"const postPetById = {\r",
											"    url: \"https://petstore.swagger.io/v2/pet\",\r",
											"    method: \"POST\",\r",
											"    header: {\r",
											"        \"Content-Type\": \"application/json\",\r",
											"    },\r",
											"    body: JSON.stringify({\r",
											"        \"id\": 0,\r",
											"        \"category\": {\r",
											"            \"id\": 0,\r",
											"            \"name\": \"string\",\r",
											"        },\r",
											"        \"name\": \"doggie\",\r",
											"        \"photoUrls\": [\r",
											"            \"string\"\r",
											"        ],\r",
											"        \"tags\": [\r",
											"            {\r",
											"                \"id\": 0,\r",
											"                \"name\": \"string\"\r",
											"            }\r",
											"        ],\r",
											"        \"status\": \"available\"\r",
											"    })\r",
											"};\r",
											"\r",
											"pm.sendRequest(postPetById, function (err, response) {\r",
											"    let responseId = response.text().replace(/([^\"\\w-])([-0-9.]{8,100})([^\"\\w-])/g, '$1\\\"$2\\\"$3');\r",
											"    let jsonData = JSON.parse(responseId);\r",
											"    let id = jsonData.id.replace('\"', '');\r",
											"    pm.environment.set(\"env_petId\", id);\r",
											"});"
