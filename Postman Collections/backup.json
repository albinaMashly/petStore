											"pm.environment.set(\"env_petId\", id);",
											"",
											"//console.log(\"collection status is \" + pm.collectionVariables.get(\"collection_status\"));",
											"//console.log(\"global url is \" + pm.globals.get(\"global_baseUrl\"));",
											"//console.log(\"environment pet ID is \" + pm.environment.get(\"env_petId\"));",
											"",
											"pm.test(\"TC 001: Verify that pet is created\", function () {",
											"    pm.response.to.have.status(200);",
											"});",
											"",
											"pm.test(\"TC 002: Verify that response time is as expected\", function () {",
											"    pm.expect(pm.response.responseTime).to.be.above(250);",
											"});",
											"",
											"const getPetById = {",
											"    url: \"https://petstore.swagger.io/v2/pet/\" + pm.environment.get(\"env_petId\"),",
											"    method: \"GET\",",
											"    header: {",
											"        \"Content-Type\": \"application/json\",",
											"        },",
											"};",
											"",
											"//setTimeout(() => {",
											"    //pm.sendRequest(getPetById, function (err, response) {",
											"        //pm.test(\"TC 003: Verify that pet is retrieved with correct status\", function () {",
											"            //pm.expect(response.json().status).to.equal(\"available\");",
											"        //});",
											"    //});",
											"//}, 3000);",
											"",
											"// Visualization: Display response as table",
											"var template = `",
											"<style>",
											"  body { font-family: Arial, sans-serif; padding: 10px; }",
											"  table { border-collapse: collapse; width: 100%; }",
											"  th, td { border: 1px solid #ddd; padding: 8px 12px; text-align: left; }",
											"  th { background-color: #4CAF50; color: white; }",
											"  tr:nth-child(even) { background-color: #f2f2f2; }",
											"</style>",
											"<table>",
											"  <thead>",
											"    <tr><th>Field</th><th>Value</th></tr>",
											"  </thead>",
											"  <tbody>",
											"    {{#each response}}",
											"    <tr>",
											"      <td>{{@key}}</td>",
											"      <td>{{this}}</td>",
											"    </tr>",
											"    {{/each}}",
											"  </tbody>",
											"</table>`;",
											"",
											"function constructVisualizerPayload() {",
											"    var res = pm.response.json();",
											"    var flat = {};",
											"    Object.keys(res).forEach(function(key) {",
											"        var val = res[key];",
											"        if (typeof val === 'object' && val !== null) {",
											"            flat[key] = JSON.stringify(val);",
											"        } else {",
											"            flat[key] = val;",
											"        }",
											"    });",
											"    return { response: flat };",
											"}",
											"",
											"pm.visualizer.set(template, constructVisualizerPayload());",
